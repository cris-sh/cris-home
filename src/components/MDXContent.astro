---
---

<div class="mdx-content">
  <slot />
</div>

<style is:global>
  .mdx-content h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    margin-top: 2rem;
    color: var(--color-heading);
  }

  .mdx-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    color: var(--color-heading);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
  }

  .mdx-content h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-heading);
  }

  .mdx-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .mdx-content ul,
  .mdx-content ol {
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .mdx-content li {
    margin-bottom: 0.5rem;
    padding-left: 0.5rem;
  }

  .mdx-content ul > li {
    list-style-type: disc;
  }

  .mdx-content ol > li {
    list-style-type: decimal;
  }

  .mdx-content li > ul,
  .mdx-content li > ol {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .mdx-content code {
    font-family: "GeistMono", monospace;
    background-color: color-mix(in oklab, var(--color-surface-strong) 80%, transparent);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
    color: var(--color-heading);
  }

  .mdx-content pre {
    background-color: color-mix(in oklab, var(--color-background) 75%, black 25%);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid var(--color-border);
  }

  .mdx-content pre code {
    background-color: transparent;
    padding: 0;
    font-size: 0.875rem;
  }

  .mdx-content blockquote {
    border-left: 4px solid color-mix(in oklab, var(--color-accent-text) 60%, transparent);
    padding-left: 1rem;
    margin-left: 0;
    margin-right: 0;
    font-style: italic;
    color: var(--color-muted);
    margin: 1.5rem 0;
  }

  .mdx-content a {
    color: var(--color-accent-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .mdx-content a:hover {
    opacity: 0.8;
  }

  .mdx-content hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .mdx-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .mdx-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .mdx-content th,
  .mdx-content td {
    border: 1px solid var(--color-border);
    padding: 0.75rem;
    text-align: left;
  }

  .mdx-content th {
    background-color: var(--color-surface-strong);
    font-weight: 600;
  }
</style>

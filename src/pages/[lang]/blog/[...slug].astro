---
import { type CollectionEntry, getCollection } from "astro:content";
import BlogPost from "../../../layouts/BlogPost.astro";
import { render } from "astro:content";
import { languages } from "../../../i18n/pages";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  
  return posts.flatMap((post) => {
    const lang = post.id.split("/")[0];
    const slug = post.id.split("/").slice(1).join("/");
    
    // Fallback if no lang prefix (though collection seems to have them)
    if (!Object.keys(languages).includes(lang)) return [];

    return {
      params: { lang, slug },
      props: post,
    };
  });
}

const { lang, slug } = Astro.params;

const posts = await getCollection("blog");
const post = posts.find((p) => {
  const [pLang, ...pSlugParts] = p.id.split("/");
  return pLang === lang && pSlugParts.join("/") === slug;
});

if (!post) {
  return Astro.redirect(`/${lang}/404`);
}

const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>
